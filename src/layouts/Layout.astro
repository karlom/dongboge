---
import "../styles/global.css";
import BackToTop from "../components/BackToTop.astro";
import BaseHead from "../components/BaseHead.astro";
import { serializeJsonLd } from "../data/siteFacts";

export interface Props {
  title: string;
  description?: string;
  structuredData?: Record<string, unknown>;
}

const { title, description = "", structuredData } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} author="杨东波" />
    <meta name="theme-color" content="#fbbf24" />
    {structuredData && (
      <script type="application/ld+json" set:html={serializeJsonLd(structuredData)} />
    )}
    <slot name="head" />
  </head>
  <body>
    <slot />
    <BackToTop />

    <!-- 百度统计 - 放在页面底部，异步加载 -->
    <script is:inline>
      var _hmt = _hmt || [];
      (function () {
        var hm = document.createElement("script");
        hm.src = "https://hm.baidu.com/hm.js?8c40c8dbf76777c0e465bf533688d112";
        var s = document.getElementsByTagName("script")[0];
        if (s && s.parentNode) {
          s.parentNode.insertBefore(hm, s);
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: system-ui, sans-serif;
    background: #fff;
    background-size: 224px;
  }
  code {
    background-color: #f3f4f6;
    border-radius: 0.25rem;
    padding: 0.125rem 0.25rem;
  }
</style>
