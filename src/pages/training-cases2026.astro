                  <h3 class="text-2xl font-bold text-slate-900 mb-3">{case_.name}</h3>
                  <p class="text-lg font-semibold text-slate-800 mb-4">{case_.headline}</p>
                  <p class="text-base text-slate-600 leading-relaxed mb-5">{case_.summary}</p>

                  <div class="grid sm:grid-cols-2 gap-3 mb-5">
                    <div class="rounded-2xl bg-slate-50 p-4">
                      <div class="text-xs uppercase tracking-[0.2em] text-slate-500 mb-2">地点 / 形式</div>
